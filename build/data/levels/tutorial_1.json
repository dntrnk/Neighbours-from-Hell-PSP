    "tutorial_phrases": [
		{
			"phrase_texts": [
				{"text": "Добро пожаловать на сьемки сериала 'Как достать соседа'. Меня зовут Джо.", "y": 2},
				{"text": "Я тут режиссер.", "y": 12},
				{"text": "В следующих трех сериях вы узнаете, как помочь нашему герою Вуди строить", "y": 28},
				{"text": "различные пакости соседу, который его окончательно достал.", "y": 38},
				{"text": "Вы будете руководить Вуди с помощью стрелочек.", "y": 54},
				{"text": "Для начала отведите Вуди к зеленой отметке слева от него.", "y": 70}
			],
			
			"window_size": 15
		},

		{
			"phrase_texts": [
				{"text": "Отлично! Следующая отметка расположена в комнате А.", "y": 2},
				{"text": "Замок с двери в комнату А снят.", "y": 12},
				{"text": "Чтобы войти в дверь, зажмите стрелочку, направляющую к ней.", "y": 28}
			],
			
			"window_size": 0
		},

		{
			"phrase_texts": [
				{"text": "Замечательно! На экране видна лишь часть дома.", "y": 2},
				{"text": "Чтобы рассмотреть дом целиком, 'прокрутите' экран, двигая аналоговым стиком.", "y": 18},
				{"text": "'Прокрутите' экран влево и отправьте Вуди ко второй отметке.", "y": 34}
			],
			
			"window_size": 3
		},

		{
			"phrase_texts": [
				{"text": "Двери на задней стене соединяют этажи дома. Каждая дверь ведет к параллельно", "y": 2},
				{"text": "расположенной двери на этаж выше или ниже.", "y": 12},
				{"text": "Чтобы подвести Вуди к третьей отметке, подойдите к двери на задней стене,", "y": 28},
				{"text": "зажмите стрелочку 'вверх', а затем 'вправо', когда Вуди окажется на первом этаже.", "y": 38}
			],
			
			"window_size": 4
		},

		{
			"phrase_texts": [
				{"text": "Чудесно! Теперь вы можете легко путешествовать с Вуди по дому, подводить его к", "y": 2},
				{"text": "предметам, открывать двери и переходить из комнаты в комнату.", "y": 12},
				{"text": "Выведите Вуди из дома через входную дверь, чтобы успешно завершить серию.", "y": 28}
			],
			
			"window_size": 1
		},

